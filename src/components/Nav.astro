---
import site from "../data/site.json";
---

<header class="sticky top-0 z-40 backdrop-blur bg-ink-950/70 border-b border-white/5">
  <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="#top" class="flex items-center gap-2 group">
      <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-brand-500 to-brand-700 flex items-center justify-center font-semibold text-white text-sm">
        UT
      </div>
      <span class="font-semibold text-ink-100 group-hover:text-white transition-colors">
        {site.name}
      </span>
    </a>

    <nav class="hidden sm:flex items-center gap-6 text-sm">
      <a href="#projects" class="text-ink-400 hover:text-ink-100 transition-colors">Projects</a>
      <a href="#about" class="text-ink-400 hover:text-ink-100 transition-colors">About</a>
      <a href="#newsletter" class="text-ink-400 hover:text-ink-100 transition-colors">Newsletter</a>
      <a
        href={site.links.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="text-ink-400 hover:text-ink-100 transition-colors"
      >
        LinkedIn
      </a>
    </nav>
  </div>
</header>
