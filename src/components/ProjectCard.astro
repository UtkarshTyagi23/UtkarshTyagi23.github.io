---
interface Props {
  project: {
    slug: string;
    title: string;
    tagline: string;
    description: string;
    tags: string[];
    video: {
      type: "mp4" | "youtube";
      src: string;
      poster?: string;
    };
    links: {
      github?: string | null;
      demo?: string | null;
    };
  };
}

const { project } = Astro.props;

// For YouTube, accept either a full watch URL or just an embed URL.
function youtubeEmbed(src: string): string {
  if (src.includes("youtube.com/embed/")) return src;
  const m = src.match(/(?:v=|youtu\.be\/)([\w-]{11})/);
  return m ? `https://www.youtube.com/embed/${m[1]}` : src;
}
---

<article
  id={project.slug}
  class="project-card group rounded-2xl bg-ink-900/60 border border-white/10 overflow-hidden flex flex-col"
>
  {/* Video / placeholder */}
  <div class="relative aspect-video bg-ink-900 overflow-hidden">
    {project.video.type === "mp4" ? (
      <video
        class="w-full h-full object-cover"
        src={project.video.src}
        poster={project.video.poster}
        controls
        preload="metadata"
        playsinline
      >
        <p class="text-ink-400 text-sm p-4">
          Your browser doesn't support HTML5 video.
          <a href={project.video.src} class="text-brand-400 underline">Download the demo</a>.
        </p>
      </video>
    ) : (
      <iframe
        class="w-full h-full"
        src={youtubeEmbed(project.video.src)}
        title={`${project.title} demo`}
        loading="lazy"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
      ></iframe>
    )}
  </div>

  {/* Body */}
  <div class="p-6 flex flex-col flex-1">
    <h3 class="text-xl font-semibold text-white">{project.title}</h3>
    <p class="mt-1 text-sm text-brand-300">{project.tagline}</p>
    <p class="mt-4 text-sm text-ink-400 leading-relaxed">{project.description}</p>

    <div class="mt-5 flex flex-wrap gap-1.5">
      {project.tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>

    <div class="mt-6 pt-4 border-t border-white/5 flex flex-wrap gap-4 text-sm">
      {project.links.github && (
        <a
          href={project.links.github}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 text-ink-300 hover:text-white transition-colors"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2c-3.2.7-3.87-1.37-3.87-1.37-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.24 3.34.95.1-.74.4-1.24.72-1.53-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.15 1.18.91-.25 1.89-.38 2.86-.38.97 0 1.95.13 2.86.38 2.18-1.49 3.14-1.18 3.14-1.18.62 1.58.23 2.75.11 3.04.74.81 1.18 1.84 1.18 3.1 0 4.43-2.69 5.41-5.25 5.69.41.36.78 1.06.78 2.13v3.16c0 .31.21.67.79.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z" />
          </svg>
          Source
        </a>
      )}
      {project.links.demo && (
        <a
          href={project.links.demo}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 text-ink-300 hover:text-white transition-colors"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
          Live demo
        </a>
      )}
    </div>
  </div>
</article>
