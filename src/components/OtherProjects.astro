---
import other from "../data/other-projects.json";
---

<section id="other-projects" class="py-20 sm:py-24 border-t border-white/5 bg-ink-900/30">
  <div class="max-w-5xl mx-auto px-6">
    <div class="mb-10 max-w-2xl">
      <p class="text-sm font-medium text-brand-400 mb-2 tracking-wide uppercase">
        Selected coursework
      </p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white tracking-tight">
        More work
      </h2>
      <p class="mt-4 text-ink-400 leading-relaxed">
        Smaller projects from coursework and side investigations — focused
        write-ups of single modelling decisions rather than full systems.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-4">
      {other.map((p: any) => (
        <div class="rounded-xl bg-ink-900/60 border border-white/10 p-5 hover:border-brand-500/30 transition-colors">
          <h3 class="text-base font-semibold text-white">{p.title}</h3>
          <p class="mt-2 text-sm text-ink-400 leading-relaxed">{p.description}</p>
          <div class="mt-4 flex flex-wrap gap-1.5">
            {p.tags.map((t: string) => <span class="tag">{t}</span>)}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
