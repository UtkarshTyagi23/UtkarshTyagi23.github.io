---
import experience from "../data/experience.json";
---

<section id="experience" class="py-20 sm:py-24 border-t border-white/5">
  <div class="max-w-5xl mx-auto px-6 grid lg:grid-cols-3 gap-10">
    <div class="lg:col-span-1">
      <p class="text-sm font-medium text-brand-400 mb-2 tracking-wide uppercase">Experience</p>
      <h2 class="text-3xl font-bold text-white tracking-tight">Where I've worked</h2>
      <p class="mt-4 text-sm text-ink-400 leading-relaxed">
        Four years across enterprise analytics, ML deployment, and now agentic
        AI for finance.
      </p>
    </div>

    <div class="lg:col-span-2 relative">
      <div class="absolute left-3 top-2 bottom-2 w-px bg-white/10 hidden sm:block"></div>
      <ol class="space-y-10">
        {experience.map((job) => (
          <li class="relative sm:pl-10">
            <div class="hidden sm:block absolute left-0 top-1.5 w-6 h-6 rounded-full bg-ink-900 border-2 border-brand-500 flex items-center justify-center">
              {job.current && (
                <span class="absolute inset-0 rounded-full bg-brand-500/40 animate-ping"></span>
              )}
              <span class="relative w-2 h-2 rounded-full bg-brand-500"></span>
            </div>
            <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
              <h3 class="text-lg font-semibold text-white">
                {job.role} · <span class="text-brand-300">{job.company}</span>
              </h3>
              <span class="text-xs font-mono text-ink-500 tracking-wide">{job.period}</span>
            </div>
            <p class="text-xs text-ink-500 mt-1">{job.location}</p>
            <ul class="mt-3 space-y-2 text-sm text-ink-400 leading-relaxed">
              {job.bullets.map((b) => (
                <li class="flex gap-2">
                  <span class="text-brand-500 mt-1.5 flex-shrink-0">▸</span>
                  <span>{b}</span>
                </li>
              ))}
            </ul>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>
