---
import ProjectCard from "./ProjectCard.astro";
import projects from "../data/projects.json";
---

<section id="projects" class="relative py-20 sm:py-24">
  <div class="max-w-5xl mx-auto px-6">
    <div class="mb-12 max-w-2xl">
      <p class="text-sm font-medium text-brand-400 mb-2 tracking-wide uppercase">
        Featured projects
      </p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white tracking-tight">
        Things I've built
      </h2>
      <p class="mt-4 text-ink-400">
        End-to-end ML systems with a usable front-end and a clear decision the
        end user can act on. Each card includes a short video walkthrough.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-6">
      {projects.map((p: any) => <ProjectCard project={p} />)}
    </div>
  </div>
</section>
