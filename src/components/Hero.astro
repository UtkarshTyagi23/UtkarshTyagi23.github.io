---
import site from "../data/site.json";
---

<section id="top" class="relative overflow-hidden">
  <div class="hero-glow"></div>
  <div class="relative max-w-5xl mx-auto px-6 pt-20 pb-20 sm:pt-28 sm:pb-24">
    <div class="max-w-3xl">
      <p class="text-sm font-medium text-brand-400 mb-4 tracking-wide uppercase">
        {site.role} · {site.location}
      </p>
      <h1 class="text-4xl sm:text-6xl font-bold text-white leading-tight tracking-tight">
        Hi, I'm {site.name.split(" ")[0]}.
      </h1>
      <p class="mt-6 text-xl sm:text-2xl text-ink-300 leading-relaxed">
        {site.tagline}
      </p>

      <div class="mt-10 flex flex-wrap gap-3">
        <a
          href="#projects"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-brand-600 hover:bg-brand-500 text-white font-medium text-sm transition-colors shadow-lg shadow-brand-600/20"
        >
          See projects
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
          </svg>
        </a>
        <a
          href={site.links.github}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-white/5 hover:bg-white/10 text-ink-100 font-medium text-sm border border-white/10 transition-colors"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2c-3.2.7-3.87-1.37-3.87-1.37-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.24 3.34.95.1-.74.4-1.24.72-1.53-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.15 1.18.91-.25 1.89-.38 2.86-.38.97 0 1.95.13 2.86.38 2.18-1.49 3.14-1.18 3.14-1.18.62 1.58.23 2.75.11 3.04.74.81 1.18 1.84 1.18 3.1 0 4.43-2.69 5.41-5.25 5.69.41.36.78 1.06.78 2.13v3.16c0 .31.21.67.79.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z" />
          </svg>
          GitHub
        </a>
        <a
          href={site.links.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-white/5 hover:bg-white/10 text-ink-100 font-medium text-sm border border-white/10 transition-colors"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.36V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 11.01-4.13 2.06 2.06 0 010 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z" />
          </svg>
          LinkedIn
        </a>
      </div>
    </div>
  </div>
</section>

<section id="about" class="py-16 sm:py-20 border-t border-white/5">
  <div class="max-w-5xl mx-auto px-6 grid lg:grid-cols-3 gap-10">
    <div class="lg:col-span-1">
      <p class="text-sm font-medium text-brand-400 mb-2 tracking-wide uppercase">About</p>
      <h2 class="text-3xl font-bold text-white tracking-tight">What I work on</h2>
    </div>
    <div class="lg:col-span-2">
      <p class="text-base sm:text-lg text-ink-300 leading-relaxed">
        {site.about}
      </p>
    </div>
  </div>
</section>
