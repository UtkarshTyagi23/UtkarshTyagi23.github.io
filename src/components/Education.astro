---
import education from "../data/education.json";
---

<section id="education" class="py-20 sm:py-24 border-t border-white/5 bg-ink-900/30">
  <div class="max-w-5xl mx-auto px-6 grid lg:grid-cols-3 gap-10">
    <div class="lg:col-span-1">
      <p class="text-sm font-medium text-brand-400 mb-2 tracking-wide uppercase">Education</p>
      <h2 class="text-3xl font-bold text-white tracking-tight">Where I trained</h2>
    </div>

    <div class="lg:col-span-2 grid sm:grid-cols-2 gap-4">
      {education.map((edu) => (
        <div class="rounded-2xl bg-ink-900/60 border border-white/10 p-6 flex flex-col">
          <div class="flex items-start justify-between gap-3 mb-3">
            <h3 class="text-base font-semibold text-white leading-snug">{edu.degree}</h3>
            {edu.current && (
              <span class="text-[10px] uppercase tracking-wider px-2 py-0.5 rounded-full bg-brand-500/15 text-brand-300 border border-brand-500/30 flex-shrink-0">
                Current
              </span>
            )}
          </div>
          <p class="text-sm text-brand-300">{edu.school}</p>
          <p class="text-xs text-ink-500 mt-1 font-mono">
            {edu.period} · {edu.location}
          </p>
          <p class="mt-4 text-sm text-ink-400 leading-relaxed">{edu.notes}</p>
        </div>
      ))}
    </div>
  </div>
</section>
