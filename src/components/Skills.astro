---
import skills from "../data/skills.json";
---

<section id="skills" class="py-20 sm:py-24 border-t border-white/5">
  <div class="max-w-5xl mx-auto px-6 grid lg:grid-cols-3 gap-10">
    <div class="lg:col-span-1">
      <p class="text-sm font-medium text-brand-400 mb-2 tracking-wide uppercase">Skills</p>
      <h2 class="text-3xl font-bold text-white tracking-tight">What I work with</h2>
    </div>

    <div class="lg:col-span-2 space-y-6">
      {skills.groups.map((group) => (
        <div>
          <p class="text-xs font-mono uppercase tracking-wider text-ink-500 mb-3">
            {group.label}
          </p>
          <div class="flex flex-wrap gap-2">
            {group.items.map((item) => <span class="tag">{item}</span>)}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
